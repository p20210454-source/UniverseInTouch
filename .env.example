# Admin login (username + password form)
# Copy to .env: cp .env.example .env
# Quote passwords that contain # (otherwise everything after # is treated as a comment)
ADMIN_USERNAME=admin
ADMIN_PASSWORD='Rahul#1234'

# Optional
PORT=3000
NODE_ENV=development
# Comma-separated allowed browser origins (defaults to localhost)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
