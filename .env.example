# Admin login (username + password form)
# Copy to .env: cp .env.example .env
# Quote passwords that contain # (otherwise everything after # is treated as a comment)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Required in production (32+ random characters). Sessions are signed with this secret.
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars

# Optional
PORT=3000
NODE_ENV=development
# Set to 1 when running behind nginx/Cloudflare so rate limits use the real client IP
TRUST_PROXY=0
# Comma-separated allowed browser origins (defaults to localhost)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
